{
  "name": "sbom-support-lookup",
  "version": "1.0.0",
  "description": "Upload an SBOM, list every package's PURL, and check end-of-life status against endoflife.date - all in the browser.",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "npx --yes serve -l 5173 .",
    "test": "node --test",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-coverage-include='js/**/*.js' --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info",
    "build": "node scripts/build-standalone.js"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT"
}
